#compdef tofu

# Potential improvements:
# - Better completion for plan files
# - Better completion for tofu config directories?
# - Completion for resources
# - completion for variables?

_tofu_cmds() {
  local cmds=(
    'init:Initialize a working directory'
    'validate:Validates the tf files'
    'plan:Generate and show an execution plan'
    'apply:Builds or changes infrastructure'
    'destroy:Destroy tofu-managed infrastructure'

    'console:Interactive console for tofu expressions'
    'fmt:Rewrites config files to canonical format'
    'force-unlock:Release a stuck lock on the current workspace'
    'get:Download and install modules for the configuration'
    'graph:Create a visual graph of resources'
    'import:Import existing infrastructure into OpenTofu'
    'login:Obtain and save credentials for a remote host'
    'logout:Remove locally stored credentials for a remote host'
    'output:Read an output from a state file'
    'providers:Prints a tree of the providers used in the configuration'
    'refresh:Update local state file against real resources'
    'show:Inspect state or plan'
    'state:Advanced state management'
    'taint:Manually mark a resource for recreation'
    'test:Run tests'
    'untaint:Manually unmark a resource as tainted'
    'version:Prints the version'
    'workspace:Workspace management'
  )
  _describe -t commands 'common tofu commands' cmds "$@"
}

_tf_resource() {
  # TODO: do actual completion here
  _message "OpenTofu resource address"
}

__tofu_warning_opts=(
    '-compact-warnings[Show warnings in more compact form]'
    '-consolidate-warnings=[Combine related warnings]: :(false true)'
    '-consolidate-errors' \
)

__tofu_var_opts=(
    '*-var=[Set a variable in the configuration]:assignment'
    '*-var-file=[Set variables in the configuration from a file]:path:_files'
)

__tofu_plan_opts=(
    '-destroy[Destroy all resources]'
    '-refresh-only[Only update state to match remote resources]'
    '-refresh=[Update state prior to checking for differences]: :(false true)'
    '*-replace=[Force replacement of a resource]:resource:_tofu_resource'
    '*-target=[Resource to target]:resource:_tf_resource'
    '*-target-file=[File containing resources to target]:filename:_files'
    '*-exclude=:resource:_tofu_resource'
    '*-exclude-file=:filename:_files'
    $__tofu_var_opts
)
# TODO: array for lock opts
__tofu_lock_opts=(
    '-lock=[Lock the state file]: :(false true)'
    '-lock-timeout=[Duration to retry a state lock]:timeout'
)

_tofu-apply() {
    _arguments \
        + plan "(:)${^__tofu_plan_opts}" \
        + general \
        '-auto-approve[Skip interactive approval of plan before applying]' \
        $__tofu_warning_opts \
        '-concise' \
        $__tofu_lock_opts \
        '-input=[Ask for input for variables if not directly set]: :(false true)' \
        '-json' \
        '-show-sensitive' \
        '-deprecation=[Type of deprecation warnings]: :(module:all module:local module:none)' \
        '-no-color[Suppress color in output]' \
        '-parallelism=[Limit the number of parallel resource operations]:n' \
        '(plan)::plan-file:_files'
}

_tofu-console() {
  _arguments \
    $__tofu_var_opts \
    $__tofu_warning_opts
}

_tofu-destroy() {
    #TODO consolidate this with apply?
    _arguments \
        $__tofu_plan_opts \
        '-auto-approve[Skip interactive approval of plan before applying]' \
        $__tofu_warning_opts \
        '-concise' \
        $__tofu_lock_opts \
        '-input=[Ask for input for variables if not directly set]: :(false true)' \
        '-json' \
        '-show-sensitive' \
        '-deprecation=[Type of deprecation warnings]: :(module:all module:local module:none)' \
        '-no-color[Suppress color in output]' \
        '-parallelism=[Limit the number of parallel resource operations]:n' \
}

_tofu-fmt() {
  _arguments \
    "-list=[Whether to list files whose formatting differs]: :(false true)" \
    '-write=[Whether to write to source files]: :(false true)' \
    '-diff[Display diffs of formatting changes]' \
    '-check[Check if the input is formatted]' \
    '-no-color' \
    '-recursive[Also process files in subdirectories]' \
    '*::target:_files'
}

_tofu-get() {
  _arguments \
    '-update[Check already-downloaded modules for available updates]' \
    '-no-color[Disable text coloring in the output]' \
    '-test-directory=:path:_files -/' \
    '-json' \
    $__tofu_var_opts
}

_tofu-graph() {
  _arguments \
    '-plan=[Use specified plan file]:tfplan:_files' \
    '-draw-cycles[Highlight any cycles in the graph]' \
    '-module-depth=[Specifies the depth of the modules to show in the output]:n' \
    '-type=[Type of graph to output]:type:(plan plan-refresh-only plan-destroy apply)' \
    $__tofu_var_opts
}

_tofu-import() {
  _arguments \
    '-config=[Path to config directory]:path:_files -/' \
    '-allow-missing-config[Allow import when no resource configuration exists]' \
    '-input=[Ask for input for variables if not directly set]: :(false true)' \
    $__tofu_lock_opts \
    '-no-color[Suppress color in output]' \
    '-ignore-remote-version' \
    $__tofu_var_opts \
    $__tofu_warning_opts \
    ':resource:_tf_resource' \
    ':id'
}

_tofu-init() {
  _arguments \
    '-backend=[Configure backend]: :(false true)' \
    '*-backend-config=[Override for backend configuration]: : _alternative path\:path\:_files assignment\:assignment' \
    '-force-copy[Suppress prompts about copying state data]' \
    '-from-module=[Copy contents of the given module into target directory]:source:_files -/' \
    '-get=[Download any modules]: :(false true)' \
    '-input=[Ask for input if necessary]: :(false true)' \
    $__tofu_lock_opts \
    '-no-color[Suppress color in output]' \
    '-plugin-dir=[Directory containing plugin binaries]:path:_files -/' \
    '-reconfigure[Reconfigure the backend]' \
    '-migrate-state[Attempt to migrate state to new backend]' \
    '-upgrade[Ignore previously installed objects and install latest]' \
    '-lockfile=[Set dependency lockfile mode]: :(readonly)' \
    '-ignore-remote-version[Ignore checking that local and remote versions are compatible]' \
    '-test-directory=:path:_files -/' \
    '-json' \
    $__tofu_var_opts \
    $__tofu_warning_opts
}

_tofu-login() {
  _arguments '::hostname:'
}

_tofu-logout() {
  _arguments '::hostname:'
}

_tofu-output() {
  _arguments \
    '-no-color[Suppress color in output' \
    '-json' \
    '-raw[Print raw string directly if possible]' \
    '-show-sensitive' \
    $__tofu_var_opts \
    ':output'
}

_tofu-plan() {
    _arguments \
        $__tofu_plan_opts \
        $__tofu_warning_opts \
    '-detailed-exitcode' \
    '-input=[Ask for input for variables if not directly set]: :(false true)' \
    '-generate-config-out=[Location for generated hcl]:path:_files' \
    $__tofu_lock_opts \
    '-out=[Write a plan file to the given path]:path:_files' \
    '-no-color' \
    '-concise' \
    '-json' \
    '-deprecation=: :(module:all module:local module:none)' \
    '-parallelism=[Limit the number of parallel resource operations]:n'
}

_tofu-providers() {
  local context state state_descr line
  integer ret=1
  typeset -A opt_args
  local subcommands=(
    'lock:"Write out dependency locks"'
    'mirror:"Save local copies of providers"'
    'schema:"Show schemas for the providers used"'
  )

  _arguments -C \
      $__tofu_var_opts \
      '-test-directory=:path:_files -/' \
      ":subcommand: _describe -t commands subcommand subcommands" '*:: :->args' && ret=0

  if [[ $state = args ]]; then
    local oses=(linux darwin windows freebsd)
    local archs=(amd64 arm64 arm 386)
    case "${line[1]}" in
      lock)
        _arguments \
          '-fs-mirror=[Consult given filesystem mirror directory]:dir:_files -/' \
          '-net-mirror=[Consult the given network mirror]:url:_message url' \
          '-platform=[Choose target platform]:os_arch:_sep_parts oses _ archs'
        ;;
      mirror)
        _arguments '-platform=[Choose target platform]:os_arch:_sep_parts oses _ archs'
        ;;
      schema)
        (( CURRENT == 2 )) && compadd -- -json
        ;;
    esac
  fi
  return ret
}

_tofo-refresh() {
  _arguments \
      $__tofu_warning_opts \
      '-input=[Ask for input for variables if not directly set]: :(false true)' \
      $__tofu_lock_opts \
      '-no-color[Suppress color in output]' \
      '-concise' \
      '*-target=[Resource to target]:resource:_tf_resource' \
      '*-exclude=resource:_tf_resource' \
      $__tofu_var_opts \
      '-json'
  }

_tofu-show() {
    _arguments \
        '-no-color' \
        '-json' \
        '-show-sensitive' \
        $__tofu_var_opts \
        + '(target)' \
        '-state[Show latest state snapshot]'  \
        '-plan=[Show saved plan]:filename:_files' \
        '-config[Show current configuration]'
}

_tofu-taint() {
  _arguments \
    '-allow-missing[Succeed even if the resource is missing]' \
    $__tofu_lock_opts \
    '-ignore-remote-version' \
    $__tofu_var_opts \
    ':resource:_tf_resource'
}

_tofu-untaint() {
  _arguments \
    '-allow-missing[Succeed even if the resource is missing]' \
    $__tofu_lock_opts \
    '-ignore-remote-version' \
    $__tofu_var_opts \
    ':resource:_tf_resource'
}

_tofu-validate() {
    _arguments \
        $__tofu_warning_opts \
        '-json' \
        '-no-color' \
        '-no-tests' \
        '-test-directory=:path:_files -/' \
        $__tofu_var_opts
}

_tofu-workspace() {
  if [[ $CURRENT -eq 2 ]]; then
    local cmds=(
      'delete:Delete a workspace'
      'list:List workspaces'
      'new:Create a workspace'
      'select:Select a workspace'
      'show:Show the name of the current workspace'
    )
    _describe -t commands 'workspace command' cmds
  else
    cmd=${words[2]}
    compset -n 2
    case $cmd in
      (new)
        _arguments \
            $__tofu_lock_opts \
            $__tofu_var_opts \
            ':name'
        ;;
      (delete)
        _arguments \
            $__tofu_lock_opts \
            $__tofu_var_opts \
            '-force' \
            ':name'
        ;;
      (list)
        _arguments $__tofu_var_opts
        ;;
      (select)
        _arguments \
            $__tofu_var_opts \
            '-or-create=: :(true false)' \
            ':name'
        ;;
    esac
  fi
}

_tofu-force-unlock() {
  _arguments $__tofu_var_opts '-force[Skip confirmation input]' ':lock-id'
}

_tofu-state() {
  local context curcontext="$curcontext" state state_descr line
  integer ret=1
  typeset -A opt_args
  subcommands=(
    'list:List resources in the state'
    'mv:Move an item in the state'
    'pull:Pull current state and output to stdout'
    'push:Update remote state from a local state file'
    'replace-provider:Replace provider for resources'
    'rm:Remove instances from the state'
    'show:Show a resource in the state'
  )
  _arguments -C ":subcommand: _describe subcommand subcommands" '*:: :->args' && ret=0
  if [[ $state = args ]]; then
    curcontext="${curcontext%:*:*}:tofu-state-$line[1]:"
    _call_function ret _tofu-state-${line[1]} && ret=0
  fi
  return ret
}

_tofu-state-list() {
  _arguments \
    '-id=[Filter the results by id of instances]:ID' \
    $__tofu_var_opts \
    '-state=:statefile:_files' \
    '*:address:_tf_resource'
}

_tofu-state-mv() {
  _arguments \
    '-dry-run[Print out what would be moved without actually moving anything]' \
    $__tofu_lock_opts \
    '-ignore-remote-version' \
    $__tofu_var_opts \
    ':source:_tf_resource' ':destination:_tf_resource'
}

_tofu-state-push() {
  _arguments \
    '-force[Force writing state regardless of lineage]' \
    $__tofu_lock_opts \
    $__tofu_var_opts \
    ':path:_files'
}

_tofu-state-pull() {
    _arguments $__tofu_var_opts
}

_tofu-state-rm() {
  _arguments \
    '-dry-run[Print out what would be removed without actually removing anything]' \
    $__tofu_lock_opts \
    '-ignore-remote-version' \
    $__tofu_var_opts \
    '*:address:_tf_resource'
}

_tofu-state-show() {
  _arguments \
      $__tofu_var_opts \
      -show-sensitive \
      '-state=:statefile:_files' \
      ':address:_tf_resource'
}

_tofu-replace-provider() {
  _arguments \
    '-auto-approve[Skip interactive approval of plan before applying]' \
    $__tofu_lock_opts \
    '-ignore-remote-version' \
    $__tofu_var_opts \
    ':from-provider-fqdn' ':to-provider-fqdn'
}

_tofu() {
  local context curcontext="$curcontext" state state_descr line
  integer ret=1
  typeset -A opt_args
  _arguments -C '(- :)-version' '(-)-help' \
    '-chdir=-[Switch to different working directory]:dir:_files -/' \
    '1:command:_tofu_cmds' \
    '*:: :->args' && ret=0

  if [[ $state = args ]]; then
    curcontext="${curcontext%:*:*}:tofu-$line[1]:"
    _call_function ret _tofu-${line[1]} && ret=0
    (( ret )) && _message "no more arguments"
  fi

  return ret
}

_tofu "$@"
